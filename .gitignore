.DS_Store
.history

# Build output (rebuilt by npm run build)
dist/

# Generated skills (resolved from content/skills/ templates during scaffold build)
/skills/

# Scaffold — preserve state files, ignore dashboard
.scaffold/dashboard.html
.superpowers/

# Coverage output (kcov)
coverage/

# Node.js / TypeScript v2
# Bare pattern (no trailing slash) so a top-level `node_modules` *symlink* — the
# git-worktree dev trick of linking to the primary checkout's deps — is ignored
# too. A `node_modules/` (dir-only) pattern would not match the symlink.
node_modules

# Temp files (atomic writes)
*.tmp

# Runtime artifacts
.remember/tmp/*.pid
.remember/logs/

# Editor backups
*~
*.bak

# Git worktrees
.worktrees/

# Claude Code transient runtime locks
.claude/scheduled_tasks.lock
.claude/*.lock

# Playwright MCP test artifacts
tests/screenshots/current/
tests/screenshots/diff/
tests/screenshots/dashboard-test.html
.playwright-mcp/

# >>> scaffold managed
.scaffold/generated/
.scaffold/lock.json
.scaffold/review-attempts/
.scaffold/*.tmp
.scaffold/**/*.tmp
.scaffold/identity.json
.scaffold/activity.jsonl
.scaffold/activity-archive/
# <<< scaffold managed
