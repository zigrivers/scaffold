.DS_Store
.history

# Build output (rebuilt by npm run build)
dist/

# Generated skills (resolved from content/skills/ templates during scaffold build)
/skills/

# Beads local database (legacy, may still exist on disk)
.beads/

# Scaffold — preserve state files, ignore dashboard
.scaffold/dashboard.html
.superpowers/

# Coverage output (kcov)
coverage/

# Node.js / TypeScript v2
node_modules/

# Temp files (atomic writes)
*.tmp

# Runtime artifacts
.remember/tmp/*.pid
.remember/logs/

# Editor backups
*~
*.bak

# Git worktrees
.worktrees/

# Playwright MCP test artifacts
tests/screenshots/current/
tests/screenshots/diff/
tests/screenshots/dashboard-test.html
.playwright-mcp/

# >>> scaffold managed
.scaffold/generated/
.scaffold/lock.json
.scaffold/*.tmp
.scaffold/**/*.tmp
# <<< scaffold managed
