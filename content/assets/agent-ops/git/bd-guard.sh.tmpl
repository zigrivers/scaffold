#!/usr/bin/env bash
# bd-guard.sh — refuses destructive Beads commands against a populated database.
# Installed by `scaffold agent-ops install --component git`.
#
# Two modes:
#   1. Claude Code PreToolUse hook (default): reads the hook JSON envelope on
#      stdin, inspects .tool_input.command, exits 2 (block, stderr shown to the
#      agent) or 0 (allow). Registered under hooks.PreToolUse, matcher "Bash".
#   2. CLI check for other harnesses/scripts: bd-guard.sh --check "<command>"
#      — same exit semantics.
#
# Why: bootstrap/reset on a populated .beads/ replaces local (usually-ahead)
# state with the often-stale Dolt remote — this silently wiped ~50 beads in a
# sibling project. The guard is an accident net, not a security boundary; the
# deliberate-reset procedure lives in docs/beads-workflow.md (Durability).
#
# Deliberately does NOT print an override recipe on block (upstream Beads'
# error-text-no-echo lesson: an agent once wiped 247 issues by copying the
# destructive command out of an error message).
set -euo pipefail

cmd=""
if [ "${1:-}" = "--check" ]; then
	cmd="${2:-}"
else
	# Hook mode: JSON envelope on stdin. jq is required to parse it; without
	# jq, fail open — a guard that blocks every Bash call is worse than none.
	if ! command -v jq >/dev/null 2>&1; then
		printf '%s\n' "bd-guard: jq not found — cannot parse hook input; allowing. Install jq to arm the guard." >&2
		exit 0
	fi
	cmd="$(jq -r '.tool_input.command // empty' 2>/dev/null || true)"
fi
[ -n "$cmd" ] || exit 0

# Match-only normalized copy: FOLD backslash line-continuations into one logical
# line, but KEEP bare newlines as the command separators they are (a multiline
# block's second command must still be inspected — collapsing newlines to spaces
# would hide it). NEVER executed — used only for matching.
scan=$(printf '%s' "$cmd" | awk 'BEGIN{ORS=""} { if (sub(/\\$/,"")) printf "%s", $0; else print $0 "\n" }')

# Deliberate, human-approved override via the REAL environment variable (applies
# globally; the inline `BEADS_DESTRUCTIVE_OK=1 <cmd>` form is honored per-segment
# below). Procedure documented in docs/beads-workflow.md — not here.
if [ "${BEADS_DESTRUCTIVE_OK:-0}" = "1" ]; then exit 0; fi

# Populated-DB check — guard only when there is state to lose. Judge the current
# checkout AND, if the command retargets one with `bd -C <dir>` / `--directory
# <dir>`, that target too (a destructive `bd -C <populated> bootstrap` run from
# an empty cwd must still be caught).
target=""
if [[ "$scan" =~ (-C|--directory)(=|[[:space:]]+)([^[:space:]]+) ]]; then
	target="${BASH_REMATCH[3]}"
fi
db_populated() {
	local base="${1:-.}"
	[ -d "$base/.beads/embeddeddolt" ] && return 0
	[ -d "$base/.beads/dolt" ] && return 0
	compgen -G "$base/.beads/*.db" >/dev/null 2>&1
}
populated=0
db_populated "." && populated=1
if [ -n "$target" ]; then
	# A retarget we cannot resolve to a concrete path — a shell variable, tilde,
	# glob, command substitution, or a quoted path whose spaces truncate the
	# captured token — must be treated as populated: a destructive command aimed
	# at a checkout we can't prove empty is exactly the accident to prevent (the
	# deliberate case uses BEADS_DESTRUCTIVE_OK=1).
	case "$target" in
		*'$'* | *'`'* | *'~'* | *'*'* | *'"'* | *"'"*) populated=1 ;;
		*) db_populated "$target" && populated=1 ;;
	esac
fi
[ "$populated" = "1" ] || exit 0

# The destructive token must be the COMMAND the segment RUNS, not a word that
# merely appears inside it — otherwise `bd create "fix the bd bootstrap trap"` or
# `git commit -m "explain bd bootstrap"` (pervasive in Beads projects) would be
# blocked. So each pattern is anchored to the START of the (already
# whitespace-stripped) segment, permitting only: an optional subshell/brace
# opener, a bounded set of leading wrapper keywords (sudo/time/…), leading
# VAR=value env-assignments, and an optional path prefix before the binary. `opt`
# permits global option tokens (e.g. `-C <dir>`, `--db <path>`) between `bd` and
# its subcommand so `bd -C /x bootstrap` is caught; the path prefix catches
# `/opt/homebrew/bin/bd`; `.beads` is anchored to a real boundary so
# `.beads-backups` is not a false positive.
#
# KNOWN, ACCEPTED limits (this is an accident net, not a security boundary; see
# the header): a destructive command hidden inside command substitution
# (`$(bd bootstrap)`), behind an escaped separator, in a `-C` target with spaces,
# or reached by `cd`-ing into a *different* populated checkout from an unpopulated
# cwd is NOT caught. The layered durability defenses (push-before-reset, the
# committed JSONL restore copy, the `bd backup` full-history copy, and bd's own
# destroy-token refusals) are the real guarantee.
start='^[({]?[[:space:]]*((sudo|time|command|env|nice|nohup)[[:space:]]+)*([A-Za-z_][A-Za-z0-9_]*=[^[:space:]]*[[:space:]]+)*([^[:space:]]*/)?'
opt='([[:space:]]+-[A-Za-z-]+(=[^[:space:]]*)?([[:space:]]+[^-[:space:]][^[:space:]]*)?)*'
dangerous="${start}bd${opt}[[:space:]]+bootstrap([[:space:]|;&)}]|\$)"
dangerous="${dangerous}|${start}bd${opt}[[:space:]]+init[^|;&]*--(force|reinit-local|discard-remote|destroy-token)"
dangerous="${dangerous}|${start}bd${opt}[[:space:]]+admin[[:space:]]+reset"
dangerous="${dangerous}|${start}rm[[:space:]][^|;&]*\.beads([[:space:]/|;&)}]|\$)"
dangerous="${dangerous}|${start}dolt[[:space:]][^|;&]*\.beads([[:space:]/|;&)}]|\$)"

# Evaluate PER command segment (split on ; & |, so || && collapse too). An inline
# override authorizes ONLY the segment it directly prefixes — so
# `BEADS_DESTRUCTIVE_OK=1 echo x && bd bootstrap` still blocks the bd segment,
# and an override attached to some other command never disarms the whole chain.
blocked=0
while IFS= read -r seg; do
	seg="${seg#"${seg%%[![:space:]]*}"}"   # strip leading whitespace
	[ -n "$seg" ] || continue
	# Inline deliberate override: a genuine leading env-assignment on THIS command.
	case "$seg" in
		BEADS_DESTRUCTIVE_OK=1[[:space:]]*) continue ;;
	esac
	if printf '%s' "$seg" | grep -qE "$dangerous"; then
		blocked=1
		break
	fi
done <<SEGMENTS
$(printf '%s' "$scan" | tr ';&|\n' '\n\n\n\n')
SEGMENTS

if [ "$blocked" = "1" ]; then
	{
		printf '%s\n' "bd-guard: BLOCKED — this command can destroy the populated Beads database (.beads/)."
		printf '%s\n' "Bootstrap/reset is for FRESH CLONES ONLY; on this checkout it would replace local"
		printf '%s\n' "beads with the (often stale) remote and silently drop unpushed work."
		printf '%s\n' "If beads may be unpushed, first run: bd stats && bd dolt commit && bd dolt push"
		printf '%s\n' "then: make beads-snapshot"
		printf '%s\n' "Deliberate-reset procedure: docs/beads-workflow.md (Durability & the bootstrap trap)."
	} >&2
	exit 2
fi
exit 0
