#!/usr/bin/env bash
# {{PROJECT_NAME}} — auto-restore timestamp-only regenerated trackers so a stray
# regen artifact never blocks `make main-sync`.
#
# Usage: heal-regen-artifacts.sh <checkout-path>
#
# For each file in <checkout-path> modified ONLY in the working tree (porcelain
# " M" — tracked, unstaged), undo its change *iff the working file is identical to
# HEAD except inside `Generated <ISO-date> <HH:MM> UTC` footers* (e.g.
# `<footer>Generated ... UTC</footer>`). Any file with a real content change — even
# on a line that also carries a timestamp — is left untouched.
#
# How it stays safe (load-bearing — this rewrites working-tree files):
#   1. Validate with a FULL-FILE byte compare of HEAD vs the working copy after
#      masking every timestamp to a constant token. A full-file compare (not an
#      aggregate of +/- diff lines) catches moved lines and end-of-file-newline
#      changes that an aggregate compare would miss. HEAD is read as a raw blob and
#      the patch is taken with --no-ext-diff --no-textconv, so a configured
#      textconv/external-diff driver cannot conceal a real change.
#   2. Restore surgically by REVERSE-APPLYING only the validated timestamp patch
#      (`git apply -R`, which re-checks context). This is race-safe: a concurrent
#      edit to the same region makes the apply fail (nothing changes), and an edit
#      elsewhere in the file is preserved — unlike a whole-file `git restore`.
#   - Never `git clean`, never delete untracked files, never touch staged content
#     (staged/added/deleted statuses are skipped).
#   - Idempotent: a clean tree is a no-op, exit 0.
#
# main-sync.sh calls this best-effort (`|| true`), so a hiccup never fails a sync.
set -euo pipefail

wt="${1:-}"
if [[ -z "$wt" ]]; then
  echo "usage: heal-regen-artifacts.sh <checkout-path>" >&2
  exit 2
fi

# The regenerated-timestamp signature. Anchored to the literal "Generated " label
# so a bare date/time appearing in real content can't match by accident.
TS_RE='Generated [0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2} UTC'
# A distinctive token a real content line is implausibly going to contain, used to
# mask timestamps before comparing HEAD vs the working copy.
TS_TOKEN='<REGEN-TIMESTAMP>'

# Files modified ONLY in the working tree (index char space, worktree char M),
# tracked. `-z` gives NUL-terminated, never-quoted paths (so non-ASCII names,
# spaces, and newlines survive); `--no-renames` keeps the two-char status prefix
# stable.
while IFS= read -r -d '' entry; do
  [[ "${entry:0:2}" == " M" ]] || continue
  path="${entry:3}"

  # Validate: the working file is byte-identical to HEAD once every timestamp is
  # masked. Redirection (`< file`) avoids any leading-dash filename hazard; the
  # HEAD side is the raw committed blob, so a textconv filter can hide nothing.
  cmp -s \
    <(git -C "$wt" show "HEAD:$path" 2>/dev/null | sed -E "s/$TS_RE/$TS_TOKEN/g") \
    <(sed -E "s/$TS_RE/$TS_TOKEN/g" < "$wt/$path" 2>/dev/null) \
    || continue

  # Capture the exact change as a raw patch (filters bypassed), then reverse-apply
  # ONLY that patch. `git apply -R` verifies context, so a racing edit makes it
  # fail cleanly (file untouched) and an edit elsewhere is preserved.
  patch="$(git -C "$wt" diff --no-color --no-ext-diff --no-textconv -- "$path" 2>/dev/null || true)"
  [[ -n "$patch" ]] || continue

  if printf '%s\n' "$patch" | git -C "$wt" apply -R - 2>/dev/null; then
    printf '→ auto-healed stray regen artifact (timestamp-only): %s\n' "$path"
  else
    printf '! skipped (concurrent change or apply failed): %s\n' "$path" >&2
  fi
done < <(git -C "$wt" status --porcelain=v1 -z --no-renames)
