#!/usr/bin/env bash
# {{PROJECT_NAME}} — auto-restore timestamp-only regenerated trackers so a stray
# regen artifact never blocks `make main-sync`.
#
# Usage: heal-regen-artifacts.sh <checkout-path>
#
# For each file in <checkout-path> modified ONLY in the working tree (porcelain
# " M" — tracked, unstaged), restore it to HEAD *iff its entire working-tree diff
# is a timestamp-only change*: the file is byte-identical to HEAD except inside
# `Generated <ISO-date> <HH:MM> UTC` footers (e.g. `<footer>Generated ... UTC</footer>`).
# Any file with a real content change — even on a line that also carries a
# timestamp — is left untouched.
#
# Safety invariants (load-bearing — this git-restores files):
#   - Restore ONLY when the removed and added diff lines are identical after every
#     timestamp is normalized to a constant token. A single non-timestamp
#     difference (prefix, suffix, or another line) leaves the file alone.
#   - Never `git clean`, never delete untracked files, never touch staged content
#     (staged/added/deleted statuses are skipped).
#   - Idempotent: a clean tree is a no-op, exit 0.
#
# main-sync.sh calls this best-effort (`|| true`), so a hiccup never fails a sync.
set -euo pipefail

wt="${1:-}"
if [[ -z "$wt" ]]; then
  echo "usage: heal-regen-artifacts.sh <checkout-path>" >&2
  exit 2
fi

# The regenerated-timestamp signature. Anchored to the literal "Generated " label
# so a bare date/time appearing in real content can't match by accident.
TS_RE='Generated [0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2} UTC'
# A distinctive token a real content line is implausibly going to contain, used to
# mask timestamps before comparing old vs new.
TS_TOKEN='<REGEN-TIMESTAMP>'

# Files modified ONLY in the working tree (index char space, worktree char M),
# tracked. `-z` gives NUL-terminated, never-quoted paths (so non-ASCII names,
# spaces, and newlines survive); `--no-renames` keeps the two-char status prefix
# stable.
while IFS= read -r -d '' entry; do
  [[ "${entry:0:2}" == " M" ]] || continue
  path="${entry:3}"

  # `--no-color` so a user's color.diff=always config can't inject ANSI escapes.
  diff="$(git -C "$wt" diff -U0 --no-color -- "$path")"

  # Content lines only, marker stripped: skip everything up to the first @@ hunk
  # header (so the ---/+++ file headers can never count), then collect the removed
  # (-) and added (+) lines separately.
  old="$(printf '%s\n' "$diff" | awk '/^@@/{h=1;next} h&&/^-/{print substr($0,2)}')"
  new="$(printf '%s\n' "$diff" | awk '/^@@/{h=1;next} h&&/^\+/{print substr($0,2)}')"

  # No content diff (e.g. a mode-only change) ⇒ nothing to heal safely.
  [[ -n "$old$new" ]] || continue

  # Necessary condition: the change must actually involve a timestamp footer.
  printf '%s\n' "$old$new" | grep -qE "$TS_RE" || continue

  # Sufficient condition (the real safety gate): the removed and added text are
  # identical once every timestamp is masked. A real edit anywhere — including on
  # a line that also carries a timestamp — makes these differ, so the file is left
  # untouched and NEVER restored over real work.
  norm_old="$(printf '%s\n' "$old" | sed -E "s/$TS_RE/$TS_TOKEN/g")"
  norm_new="$(printf '%s\n' "$new" | sed -E "s/$TS_RE/$TS_TOKEN/g")"
  [[ "$norm_old" == "$norm_new" ]] || continue

  git -C "$wt" restore -- "$path"
  printf '→ auto-healed stray regen artifact (timestamp-only): %s\n' "$path"
done < <(git -C "$wt" status --porcelain=v1 -z --no-renames)
